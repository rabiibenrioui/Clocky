{
  "expo": {
    "name": "Clocky",
    "slug": "Clocky",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/app/Clocky.png",
    "scheme": "clocky",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/app/Clocky.png",
        "backgroundImage": "./assets/app/Clocky.png",
        "monochromeImage": "./assets/app/Clocky.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.rabiibenrioui.Clocky"
    },
    "web": {
      "output": "static",
      "bundler": "metro",
      "favicon": "./assets/app/Clocky.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/app/Clocky.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "@react-native-community/datetimepicker",
      [
        "expo-notifications",
        {
          "iosDisplayInForeground": true
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "827804b4-d627-4728-845d-6b2f39f8765a"
      }
    }
  }
}
